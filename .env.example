# ── Server ────────────────────────────────────────────────────────────────
PORT=3000

# Optional: protect the backoffice with HTTP Basic Auth.
# Leave both blank to disable auth (e.g. when running behind a trusted proxy).
ADMIN_USER=admin
ADMIN_PASS=change-me

# ── Health check ──────────────────────────────────────────────────────────
# How often to check every URL (cron expression). Default: every 5 minutes.
CHECK_CRON=*/5 * * * *
# Per-request timeout in milliseconds.
CHECK_TIMEOUT_MS=10000

# ── Outgoing email (Gmail) ────────────────────────────────────────────────
# For Gmail use an "App Password" (not your normal password):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-16-char-app-password

# "From" header shown to recipients. Defaults to SMTP_USER if omitted.
MAIL_FROM=KeeperLive <your-address@gmail.com>
